name: Build SirDaba APK

on:
  push:
    branches: [ main, master ]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Unzip project
        run: unzip SirDabaDelivery-fixed.zip

      - name: Set up JDK 17
        uses: actions/setup-java@v4
        with:
          java-version: '17'
          distribution: 'temurin'

      - name: Download Gradle wrapper jar
        run: |
          mkdir -p SirDabaDelivery/gradle/wrapper
          curl -L -o SirDabaDelivery/gradle/wrapper/gradle-wrapper.jar \
            https://github.com/gradle/gradle/raw/v8.4.0/gradle/wrapper/gradle-wrapper.jar

      - name: Grant execute permission for gradlew
        run: chmod +x SirDabaDelivery/gradlew

      - name: Build Debug APK
        run: cd SirDabaDelivery && ./gradlew assembleDebug --stacktrace

      - name: Upload Debug APK
        uses: actions/upload-artifact@v4
        with:
          name: SirDaba-Debug-APK
          path: SirDabaDelivery/app/build/outputs/apk/debug/*.apk
          retention-days: 30
